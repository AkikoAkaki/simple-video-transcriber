# Videos and audio (large binaries — don't commit)
inbox/**
!inbox/.gitkeep

# Generated output
transcripts/**
!transcripts/.gitkeep

# Intermediate files
cache/**
!cache/.gitkeep

# Secrets
hf_token.txt*
.env

# User-local settings (output dir preference, etc.)
user_settings.json

# Logs
watch.log

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/
